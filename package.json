{
  "name": "rouge",
  "version": "1.0.0",
  "description": "Diablo II-inspired roguelite deckbuilder combat foundation",
  "main": "index.js",
  "scripts": {
    "assets:download": "./scripts/download-assets.sh",
    "assets:curate": "./scripts/curate-mvp-icons.sh",
    "assets:download:dark-fantasy": "./scripts/download-dark-fantasy-assets.sh",
    "assets:curate:dark-fantasy": "./scripts/curate-dark-fantasy-icons.sh",
    "seeds:sync:monsters": "node ./scripts/sync-d2-monsters.js",
    "seeds:sync:items": "node ./scripts/sync-d2-items.js",
    "seeds:sync:runes": "node ./scripts/sync-d2-runes.js",
    "seeds:sync:runewords": "node ./scripts/sync-d2-runewords.js",
    "compile": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json",
    "lint": "eslint . --max-warnings 0",
    "build:static": "node ./scripts/build.js",
    "build": "npm run compile && npm run build:static",
    "check": "npm run lint && npm run build && npm run test:compiled",
    "quality": "npm run lint && npm run build && npm run test:compiled && npm run test:e2e:built",
    "start": "npm run build && python3 -m http.server 4173",
    "test:compiled": "node --test generated/tests/*.test.js",
    "test:coverage": "npm run compile && node --experimental-test-coverage --test-coverage-lines=90 --test-coverage-branches=65 --test-coverage-functions=95 --test-coverage-include=\"generated/src/**/*.js\" --test-coverage-include=\"generated/tests/helpers/**/*.js\" --test-coverage-exclude=\"generated/src/app/main.js\" --test-coverage-exclude=\"generated/src/content/seed-loader.js\" --test generated/tests/*.test.js",
    "test:e2e:built": "node ./scripts/run-e2e.js",
    "test:e2e": "npm run build && npm run test:e2e:built",
    "test": "npm run compile && npm run test:compiled"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2"
  }
}
