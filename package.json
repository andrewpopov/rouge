{
  "name": "rogue",
  "version": "1.0.0",
  "description": "Diablo II-inspired roguelite deckbuilder combat foundation",
  "main": "index.js",
  "scripts": {
    "start": "npm run build && node scripts/tools/start-static.js",
    "dev": "tsc -p ./tsconfig.runtime.json --watch & node scripts/tools/start-static.js",
    "build": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/build.js",
    "test": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node --test generated/tests/*.test.js",
    "sim:balance": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-balance-sim.js",
    "sim:skill-audit": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-skill-audit.js",
    "sim:progression": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-progression-sim.js",
    "sim:progression-sweep": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-progression-rng-sweep.js",
    "sim:progression-class-sweep": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-progression-class-sweep.js",
    "sim:batch-report": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-batch-sim-report.js",
    "sim:batch-report:background": "node ./scripts/run-background-batch-report.js",
    "sim:orchestrate": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-balance-orchestrator.js",
    "sim:orchestrate:background": "node ./scripts/run-balance-orchestrator-background.js",
    "sim:dashboard": "node ./scripts/run-balance-dashboard.js",
    "sim:encounter-trace": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-encounter-trace.js",
    "sim:power-curve": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-power-curve-report.js",
    "sim:boss-strength": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-boss-strength-report.js",
    "sim:comprehensive-balance": "tsc -p ./tsconfig.runtime.json && tsc -p ./tsconfig.tests.json && node ./scripts/run-comprehensive-balance-report.js",
    "test:e2e": "npm run build && node ./scripts/run-e2e.js",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run lint && npm run build && node --test generated/tests/*.test.js",
    "deploy": "./scripts/deploy.sh",
    "quality": "node ./scripts/run-quality.js",
    "test:coverage": "node ./scripts/run-coverage.js",
    "seeds:sync:monsters": "node ./scripts/sync-d2-monsters.js",
    "seeds:sync:items": "node ./scripts/sync-d2-items.js",
    "seeds:sync:runes": "node ./scripts/sync-d2-runes.js",
    "seeds:sync:runewords": "node ./scripts/sync-d2-runewords.js",
    "assets:download": "./scripts/download-assets.sh",
    "assets:curate": "./scripts/curate-mvp-icons.sh",
    "screenshots": "tsc -p ./tsconfig.runtime.json && node ./scripts/take-screenshots.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
